#!/usr/bin/env python3
"""
sado — request privileged command execution from the sado daemon.

Usage: sado <command> [args...]

Environment variables (all optional — sado derives sensible defaults from CLAUDE_SESSION_ID):
  SADO_SOCKET       Unix socket path (default: /run/sado/judge.sock)
  SADO_SESSION_LOG  Path to the per-session tool call log
                    (default: /tmp/sado-sessions/<session-id>.jsonl)
  SADO_TRANSCRIPT   Path to the Claude Code session JSONL transcript
                    (default: ~/.claude/projects/<project-id>/<session-id>.jsonl,
                     derived from CLAUDE_SESSION_ID and cwd)
  SADO_GOAL         High-level description of what the agent is working on

CLAUDE_SESSION_ID is set automatically by Claude Code in every tool invocation.
No per-agent configuration is required beyond a one-time system setup.
"""

import json
import os
import socket
import sys
from pathlib import Path

SOCKET_DEFAULT = "/run/sado/judge.sock"
AGENT_LOG_ENTRIES = 20  # number of recent tool calls to include


def _resolve_session_id() -> str:
    # CLAUDE_SESSION_ID is set by Claude Code in every tool invocation
    return (
        os.environ.get("CLAUDE_SESSION_ID")
        or os.environ.get("SADO_SESSION_ID")
        or f"pid-{os.getppid()}"  # last-resort fallback for manual invocation
    )


def _resolve_transcript_path(session_id: str) -> str:
    explicit = os.environ.get("SADO_TRANSCRIPT", "")
    if explicit:
        return explicit
    if not session_id.startswith("pid-"):
        # Derive from Claude Code's storage layout:
        # ~/.claude/projects/<cwd-with-slashes-as-dashes>/<session-id>.jsonl
        home = os.path.expanduser("~")
        project_id = os.getcwd().replace("/", "-")
        return f"{home}/.claude/projects/{project_id}/{session_id}.jsonl"
    return ""


def _session_log_path(session_id: str) -> str:
    explicit = os.environ.get("SADO_SESSION_LOG", "")
    if explicit:
        return explicit
    return f"/tmp/sado-sessions/{session_id}.jsonl"


def _format_agent_log(log_path: str) -> str:
    """
    Read the last AGENT_LOG_ENTRIES lines from the session JSONL log and
    format them as a numbered list for the judge.

    Each log entry is expected to be a JSON object written by the Claude Code
    PostToolUse hook. Recognised fields: type, tool, command, exit_code, output.
    Plain-text lines are included as-is.
    """
    try:
        lines = Path(log_path).read_text().splitlines()
    except OSError:
        return "(no agent activity log found)"

    recent = [l for l in lines if l.strip()][-AGENT_LOG_ENTRIES:]
    if not recent:
        return "(agent activity log is empty)"

    formatted = []
    for i, line in enumerate(recent, 1):
        try:
            entry = json.loads(line)
            tool = entry.get("tool", entry.get("type", "unknown"))
            cmd = entry.get("command") or entry.get("input", "")
            exit_code = entry.get("exit_code")
            output = (entry.get("output") or "").strip()
            # Truncate long outputs so the prompt stays manageable
            if len(output) > 200:
                output = output[:200] + "…"
            parts = [f"[{i}] {tool}: {cmd}"]
            if exit_code is not None:
                parts.append(f"→ exit {exit_code}")
            if output:
                parts.append(f"| {output}")
            formatted.append(" ".join(parts))
        except (json.JSONDecodeError, AttributeError):
            formatted.append(f"[{i}] {line}")

    return "\n".join(formatted)


def _send_request(sock_path: str, request: dict) -> dict:
    with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as sock:
        sock.connect(sock_path)
        sock.sendall(json.dumps(request).encode() + b"\n")
        buf = b""
        while True:
            chunk = sock.recv(4096)
            if not chunk:
                break
            buf += chunk
            if b"\n" in buf:
                break
    return json.loads(buf.split(b"\n")[0])


def main() -> None:
    if len(sys.argv) < 2:
        print("Usage: sado <command> [args...]", file=sys.stderr)
        sys.exit(1)

    command = sys.argv[1]
    args = sys.argv[2:]

    sock_path = os.environ.get("SADO_SOCKET", SOCKET_DEFAULT)
    session_id = _resolve_session_id()
    transcript_path = _resolve_transcript_path(session_id)
    goal = os.environ.get("SADO_GOAL", "")

    log_path = _session_log_path(session_id)
    agent_log = _format_agent_log(log_path)

    request = {
        "command": command,
        "args": args,
        "cwd": os.getcwd(),
        "session_id": session_id,
        "agent_log": agent_log,
        "transcript_path": transcript_path,
        "goal": goal,
    }

    try:
        response = _send_request(sock_path, request)
    except OSError as exc:
        print(f"sado: cannot connect to daemon at {sock_path}: {exc}", file=sys.stderr)
        sys.exit(1)
    except json.JSONDecodeError as exc:
        print(f"sado: malformed response from daemon: {exc}", file=sys.stderr)
        sys.exit(1)

    verdict = response.get("verdict", "DENY")
    reason = response.get("reason", "")
    stdout = response.get("stdout", "")
    stderr = response.get("stderr", "")
    exit_code = int(response.get("exit_code", 1))

    if verdict == "DENY":
        print(f"sado: DENIED — {reason}", file=sys.stderr)

    if stdout:
        sys.stdout.write(stdout)
    if stderr:
        sys.stderr.write(stderr)

    sys.exit(exit_code)


if __name__ == "__main__":
    main()
